## Copy this file to `app/.env.local` and fill in real values.
## Vite only exposes env vars that start with `VITE_`.
##
## Example:
##   cp env.example .env.local
##   # edit .env.local

# Firebase web app config (optional but recommended; used by app/src/lib/firebase.js)
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""

# Firebase App Check (reCAPTCHA v3) site key (PUBLIC key; safe to be in client-side env)
VITE_APPCHECK_RECAPTCHA_V3_SITE_KEY=""

# Optional: App Check debug token (local dev)
# - "true" generates and prints a debug token
# - or set an explicit token string
# VITE_APPCHECK_DEBUG_TOKEN=true


