rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isSteveAdmin() {
      // Avoid crashing if the profile doc or username field is missing.
      return isAdmin()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && ('username' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'stevesunhy';
    }

    // Some user docs won't have a `banUntil` field. Accessing a missing field can throw in rules,
    // which would break *all* writes that call isBanned(). Treat missing/invalid banUntil as "not banned".
    //
    // NOTE: Firestore Rules is not JavaScript: no `let`, no statement `if`. Use pure expressions only.
    function banUntil(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        ? (
            ('banUntil' in get(/databases/$(database)/documents/users/$(uid)).data)
              ? get(/databases/$(database)/documents/users/$(uid)).data.banUntil
              : null
          )
        : null;
    }

    function isBanned(uid) {
      return (banUntil(uid) is timestamp) && (request.time < banUntil(uid));
    }

    // -----------------------------
    // Claims / Reports
    // -----------------------------

    match /claims/{claimId} {
      // Admin can read all; users can read their own
      allow read: if isSteveAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.subject is string
                    && request.resource.data.subject.size() > 0
                    && request.resource.data.subject.size() <= 180
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 8000
                    // Optional contact email (string)
                    && (!('email' in request.resource.data) || request.resource.data.email is string);
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      // Admin can read all; reporter can read their own
      allow read: if isSteveAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 2000
                    && request.resource.data.targetType in ['post','comment','chat','user']
                    // Proof image URL required
                    && request.resource.data.proofURL is string
                    && request.resource.data.proofURL.size() > 0
                    // Minimal target reference map
                    && request.resource.data.target is map;
      // Admin can update status fields if you add them later; keep locked for now.
      allow update, delete: if false;
    }

    function isPinnedForumId(forumId) {
      return forumId in [
        'Discussion:announcement','Discussion:general',
        'Q&A:announcement','Q&A:general',
        'Write-ups:announcement','Write-ups:general',
        'Wiki build:announcement','Wiki build:general'
      ];
    }

    function postAuthor(postId) {
      return get(/databases/$(database)/documents/communityPosts/$(postId)).data.author;
    }

    function isPostAuthor(postId) {
      return isSignedIn() && postAuthor(postId) == request.auth.uid;
    }

    // Public reads everywhere unless overridden below
    match /{document=**} {
      allow read: if true;
    }

    // -----------------------------
    // Wiki: editable by trusted users (level >= 10)
    // -----------------------------
    function myLevel(){
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/gameState/main)
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)/gameState/main).data.level
        : 0;
    }

    function canEditWiki(){
      return isSignedIn()
        && (myLevel() is int || myLevel() is float)
        && myLevel() >= 10;
    }

    match /articles/{id} {
      allow read: if true;
      function safeDifficulty(d){
        return (d is int || d is float) && d >= 0 && d <= 100;
      }

      function difficultyChanged(){
        // request.resource.data is the post-write document (including merge semantics).
        return ('difficulty' in request.resource.data)
          && (
            !('difficulty' in resource.data)
            || request.resource.data.difficulty != resource.data.difficulty
          );
      }

      allow create: if canEditWiki()
                    && ('difficulty' in request.resource.data)
                    && safeDifficulty(request.resource.data.difficulty);

      allow update: if canEditWiki()
                    // If difficulty changes, require admin claim.
                    && (!difficultyChanged() || isAdmin())
                    // If present, difficulty must be valid.
                    && (!('difficulty' in request.resource.data) || safeDifficulty(request.resource.data.difficulty));

      allow delete: if canEditWiki();
    }

    // Lightweight index for wiki listing (keeps article bodies out of the initial load).
    // articlesIndex/{id} mirrors public metadata fields from /articles/{id} but MUST NOT contain `content`.
    match /articlesIndex/{id} {
      allow read: if true;

      function safeDifficulty(d){
        return (d is int || d is float) && d >= 0 && d <= 100;
      }
      function safeRatingAvg(v){
        return (v is int || v is float) && v >= 0 && v <= 100;
      }
      function safeRatingCount(v){
        return (v is int || v is float) && v >= 0 && v <= 1000000;
      }
      function safeTitle(t){
        return t is string && t.size() > 0 && t.size() <= 120;
      }
      function safeSlug(s){
        return s is string && s.size() > 0 && s.size() <= 120;
      }

      function safeKeywords(ks){
        return (ks is list)
          && ks.size() >= 0
          && ks.size() <= 40;
      }

      function hasNoContent(){
        return !('content' in request.resource.data);
      }

      function allowedKeys(){
        return request.resource.data.keys().hasOnly(['title','slug','keywords','difficulty','ratingAvg','ratingCount']);
      }

      function difficultyChanged(){
        return ('difficulty' in request.resource.data)
          && (
            !('difficulty' in resource.data)
            || request.resource.data.difficulty != resource.data.difficulty
          );
      }

      allow create: if canEditWiki()
                    && hasNoContent()
                    && allowedKeys()
                    && ('title' in request.resource.data) && safeTitle(request.resource.data.title)
                    && ('slug' in request.resource.data) && safeSlug(request.resource.data.slug)
                    && (!('keywords' in request.resource.data) || safeKeywords(request.resource.data.keywords))
                    && (!('difficulty' in request.resource.data) || safeDifficulty(request.resource.data.difficulty))
                    && (!('ratingAvg' in request.resource.data) || safeRatingAvg(request.resource.data.ratingAvg))
                    && (!('ratingCount' in request.resource.data) || safeRatingCount(request.resource.data.ratingCount));

      allow update: if canEditWiki()
                    && hasNoContent()
                    && allowedKeys()
                    // If difficulty changes, require admin claim.
                    && (!difficultyChanged() || isAdmin())
                    && (!('title' in request.resource.data) || safeTitle(request.resource.data.title))
                    && (!('slug' in request.resource.data) || safeSlug(request.resource.data.slug))
                    && (!('keywords' in request.resource.data) || safeKeywords(request.resource.data.keywords))
                    && (!('difficulty' in request.resource.data) || safeDifficulty(request.resource.data.difficulty))
                    && (!('ratingAvg' in request.resource.data) || safeRatingAvg(request.resource.data.ratingAvg))
                    && (!('ratingCount' in request.resource.data) || safeRatingCount(request.resource.data.ratingCount));

      allow delete: if canEditWiki();
    }

    // -----------------------------
    // Wiki tags: per-user votes
    // articles/{id}/tagVotes/{uid} -> { tags: [string], updatedAt: timestamp }
    // Anyone can read; only the signed-in user can write their own vote doc.
    // -----------------------------
    match /articles/{id}/tagVotes/{uid} {
      allow read: if true;

      function isOwner(){
        return isSignedIn() && request.auth.uid == uid;
      }

      function isValidTag(t){
        // Keep tags short and simple for UI.
        // Allow letters/numbers/spaces/dashes.
        return t is string
          && t.size() >= 1
          && t.size() <= 24
          && t.matches('^[A-Za-z0-9][A-Za-z0-9 \\-]*$');
      }

      function isValidTagList(tags){
        // Avoid using `list.all(...)` because the Firebase Rules Playground has been observed
        // to throw "Invalid argument provided to call. Function: [all]" for some inputs.
        // Validate up to 12 tags with explicit index checks.
        return (tags is list)
          && tags.size() >= 0
          && tags.size() <= 12
          && (
            tags.size() == 0 ||
            (
              isValidTag(tags[0]) &&
              (
                tags.size() == 1 ||
                (
                  isValidTag(tags[1]) &&
                  (
                    tags.size() == 2 ||
                    (
                      isValidTag(tags[2]) &&
                      (
                        tags.size() == 3 ||
                        (
                          isValidTag(tags[3]) &&
                          (
                            tags.size() == 4 ||
                            (
                              isValidTag(tags[4]) &&
                              (
                                tags.size() == 5 ||
                                (
                                  isValidTag(tags[5]) &&
                                  (
                                    tags.size() == 6 ||
                                    (
                                      isValidTag(tags[6]) &&
                                      (
                                        tags.size() == 7 ||
                                        (
                                          isValidTag(tags[7]) &&
                                          (
                                            tags.size() == 8 ||
                                            (
                                              isValidTag(tags[8]) &&
                                              (
                                                tags.size() == 9 ||
                                                (
                                                  isValidTag(tags[9]) &&
                                                  (
                                                    tags.size() == 10 ||
                                                    (
                                                      isValidTag(tags[10]) &&
                                                      (
                                                        tags.size() == 11 ||
                                                        isValidTag(tags[11])
                                                      )
                                                    )
                                                  )
                                                )
                                              )
                                            )
                                          )
                                        )
                                      )
                                    )
                                  )
                                )
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          );
      }

      function hasValidUpdatedAt(){
        // `serverTimestamp()` evaluates to request.time in rules.
        // Allow missing (clients may omit) or a real timestamp.
        return !('updatedAt' in request.resource.data)
          || request.resource.data.updatedAt == request.time
          || request.resource.data.updatedAt is timestamp;
      }

      allow create: if isOwner()
                    && ('tags' in request.resource.data)
                    && isValidTagList(request.resource.data.tags)
                    && hasValidUpdatedAt();

      allow update: if isOwner()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tags','updatedAt'])
                    && ('tags' in request.resource.data)
                    && isValidTagList(request.resource.data.tags)
                    && hasValidUpdatedAt();

      allow delete: if false;
    }

    // -----------------------------
    // Wiki difficulty ratings: per-user rating (0–100)
    // articles/{id}/difficultyRatings/{uid} -> { rating: number, updatedAt?: timestamp, createdAt?: timestamp }
    // Anyone can read; only the signed-in user can write their own rating doc.
    // Aggregate (avg/count) is maintained on the parent article doc by Cloud Functions.
    // -----------------------------
    match /articles/{id}/difficultyRatings/{uid} {
      allow read: if true;

      function isOwner(){
        return isSignedIn() && request.auth.uid == uid;
      }

      function safeRating(r){
        return (r is int || r is float) && r >= 0 && r <= 100;
      }

      function hasValidUpdatedAt(){
        // `serverTimestamp()` evaluates to request.time in rules.
        // Allow missing (clients may omit) or a real timestamp.
        return !('updatedAt' in request.resource.data)
          || request.resource.data.updatedAt == request.time
          || request.resource.data.updatedAt is timestamp;
      }

      allow create: if isOwner()
                    && ('rating' in request.resource.data)
                    && safeRating(request.resource.data.rating)
                    && hasValidUpdatedAt()
                    && (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp);

      allow update: if isOwner()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating','updatedAt','createdAt'])
                    && ('rating' in request.resource.data)
                    && safeRating(request.resource.data.rating)
                    && hasValidUpdatedAt()
                    && (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp);

      allow delete: if false;
    }

    // Community posts
    match /communityPosts/{postId} {
      allow read: if true;

      // Any signed-in user can create a post where author == uid
      allow create: if request.auth != null
                    && !isBanned(request.auth.uid)
                    && request.resource.data.author == request.auth.uid
                    // New forum model
                    && request.resource.data.bigCategory is string
                    && request.resource.data.channel is string
                    && request.resource.data.subjects is list
                    && request.resource.data.subjects.size() >= 1
                    // `level` is optional metadata used by the UI for filtering.
                    // If present, it must be a string (legacy/alternate clients may omit it).
                    && (!('level' in request.resource.data) || request.resource.data.level is string)
                    // Announcements are server-only (created via Cloud Functions / Admin SDK).
                    && request.resource.data.channel != 'announcement';

      // Author can update their own post content (NOT likes/comments counters)
      allow update: if isSignedIn()
                    && resource.data.author == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'title','post','discussion','imageURLs','hasImages',
                      'bigCategory','channel','subjects','level'
                    ]);

      // Author (or admin) can delete their own post
      allow delete: if isSignedIn() && (resource.data.author == request.auth.uid || isAdmin());
    }

    // Post likes (one doc per user). Cloud Function maintains the `likes` counter on the post.
    // Explicit match (avoids any confusion about nested match scoping).
    match /communityPosts/{postId}/likes/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned(request.auth.uid) && request.auth.uid == userId;
      allow delete: if isSignedIn() && !isBanned(request.auth.uid) && request.auth.uid == userId;
      allow update: if false;
    }

    // Comments (top-level collection).
    // Each comment points to a post, and optionally to a parent comment (reply thread).
    match /comments/{commentId} {
      allow read: if true;

      function isValidReply(postId, replyToCommentId) {
        return replyToCommentId == null
          || (
            exists(/databases/$(database)/documents/comments/$(replyToCommentId))
            && get(/databases/$(database)/documents/comments/$(replyToCommentId)).data.postId == postId
          );
      }

      // Create: any signed-in user can create a comment as themselves.
      // Required fields:
      // - postId (string)
      // - author (uid)
      // - content (string)
      // - timestamp (timestamp)
      // Optional (if omitted, treated as defaults by UI):
      // - likes (0)
      // - pinned (false)
      // Optional:
      // - replyToCommentId (string|null)
      allow create: if isSignedIn()
                    && !isBanned(request.auth.uid)
                    && request.resource.data.postId is string
                    && exists(/databases/$(database)/documents/communityPosts/$(request.resource.data.postId))
                    && request.resource.data.author == request.auth.uid
                    && request.resource.data.content is string
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() <= 4000
                    && request.resource.data.timestamp is timestamp
                    && (!('likes' in request.resource.data) || request.resource.data.likes == 0)
                    && (!('pinned' in request.resource.data) || request.resource.data.pinned == false)
                    && isValidReply(request.resource.data.postId, request.resource.data.replyToCommentId);

      // Update:
      // - comment author can edit content (and set editedAt)
      // - post author/admin can pin/unpin (and set pinnedAt)
      // Disallow changing postId/author/replyToCommentId via updates.
      allow update: if isSignedIn() && (
        (
          resource.data.author == request.auth.uid
          && request.resource.data.postId == resource.data.postId
          && request.resource.data.author == resource.data.author
          && request.resource.data.replyToCommentId == resource.data.replyToCommentId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content','editedAt'])
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 4000
        )
        ||
        (
          (isPostAuthor(resource.data.postId) || isAdmin())
          && request.resource.data.postId == resource.data.postId
          && request.resource.data.author == resource.data.author
          && request.resource.data.replyToCommentId == resource.data.replyToCommentId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned','pinnedAt'])
        )
      );

      // Delete: comment author, post author, or admin.
      allow delete: if isSignedIn() && (
        resource.data.author == request.auth.uid
        || isPostAuthor(resource.data.postId)
        || isAdmin()
      );

      // Comment likes: one doc per user under the comment doc.
      match /likes/{userId} {
        allow read: if true;
        allow create: if isSignedIn() && !isBanned(request.auth.uid) && request.auth.uid == userId;
        allow delete: if isSignedIn() && !isBanned(request.auth.uid) && request.auth.uid == userId;
        allow update: if false;
      }
    }

    // User profiles: user may write own doc; everyone may read
    match /users/{uId} {
      allow read: if true;
      // Create: allow user to create their own profile once (includes username).
      allow create: if isSignedIn()
                    && request.auth.uid == uId
                    && request.resource.data.username is string
                    && request.resource.data.username.size() >= 3
                    && request.resource.data.username.size() <= 32
                    && request.resource.data.email is string;

      // Update: allow profile edits but keep `username` and `email` immutable (prevents impersonation).
      allow update: if isSignedIn()
                    && request.auth.uid == uId
                    && request.resource.data.username == resource.data.username
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'about','photoURL'
                    ]);

      // Admin moderation fields on user doc (ban).
      allow update: if isSteveAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'banUntil','banReason','bannedBy','bannedAt'
                    ])
                    && request.resource.data.bannedBy == request.auth.uid;
    }

    // Gamification state (XP/level), achievements, and badges:
    // - Readable (e.g., for profile display / leaderboards)
    // - Not directly writable by clients (Cloud Functions only)
    match /users/{uId}/gameState/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uId}/achievements/{achievementId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uId}/badges/{badgeId} {
      allow read: if true;
      allow write: if false;
    }

    // XP event log: private (owner only). No direct client writes.
    match /users/{uId}/xpEvents/{eventId} {
      allow read: if isSignedIn() && request.auth.uid == uId;
      allow write: if false;
    }

    // Per-user daily counters (private; used for caps like comments/day).
    match /users/{uId}/gameDaily/{dateKey} {
      allow read: if isSignedIn() && request.auth.uid == uId;
      allow write: if false;
    }

    // User starred posts (bookmarks).
    // Stored per-user so listing "my starred posts" is fast.
    match /users/{uId}/stars/{postId} {
      allow read: if isSignedIn() && request.auth.uid == uId;
      allow create: if isSignedIn()
                    && !isBanned(request.auth.uid)
                    && request.auth.uid == uId
                    && exists(/databases/$(database)/documents/communityPosts/$(postId))
                    && request.resource.data.createdAt is timestamp;
      allow delete: if isSignedIn() && !isBanned(request.auth.uid) && request.auth.uid == uId;
      allow update: if false;
    }

    // Forums/channels (user-creatable, admin-disable).
    // Each forum has:
    // - bigCategory (Discussion / Q&A / Write-ups / Wiki build / Chatty)
    // - channel (small category / subforum)
    // - deleted (bool)
    match /forums/{forumId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.bigCategory is string
                    && request.resource.data.channel is string
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.createdAt is timestamp
                    && (!('deleted' in request.resource.data) || request.resource.data.deleted == false);
      // Only stevesunhy (admin) can disable/enable or delete forums.
      allow update: if isSteveAdmin()
                    && !isPinnedForumId(forumId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted','deletedAt','deletedBy'])
                    && request.resource.data.deleted is bool;
      allow delete: if isSteveAdmin() && !isPinnedForumId(forumId);
    }

    // Per-user pinned chats.
    match /users/{uId}/chatPins/{chatId} {
      allow read: if isSignedIn() && request.auth.uid == uId;
      allow create: if isSignedIn()
                    && request.auth.uid == uId
                    && request.resource.data.pinnedAt is timestamp;
      allow delete: if isSignedIn() && request.auth.uid == uId;
      allow update: if false;
    }

    // Username index: usernames/{usernameLower} -> { uid }
    // Used for "add friend / message by username" without scanning all users.
    match /usernames/{uname} {
      	allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && !exists(/databases/$(database)/documents/usernames/$(uname));
      allow update, delete: if false;
    }

    // Friendships: one doc per pair of users:
    // friendships/{minUid}_{maxUid}:
    // { users:[uid1,uid2], status:'pending'|'accepted', requestedBy, requestedAt, acceptedAt? }
    match /friendships/{fid} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.users);

      allow create: if isSignedIn()
                    && request.resource.data.users is list
                    && request.resource.data.users.size() == 2
                    && (request.auth.uid in request.resource.data.users)
                    && request.resource.data.requestedBy == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Only the non-requester can accept.
      allow update: if isSignedIn()
                    && (request.auth.uid in resource.data.users)
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'accepted'
                    && resource.data.requestedBy != request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'status','acceptedAt','acceptedBy','updatedAt'
                    ]);

      // Either participant can delete (decline/cancel)
      allow delete: if isSignedIn() && (request.auth.uid in resource.data.users);
    }

    // Chats: private to participants. (Cloud Functions maintain unread counts + lastMessage.)
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);

      // Client can create a chat doc that includes themselves.
      allow create: if isSignedIn()
                    && !isBanned(request.auth.uid)
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() >= 2
                    && (request.auth.uid in request.resource.data.participants);

      // Disallow client updates (use Cloud Functions for lastMessage/unreadCounts).
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
                    && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        function isValidMessageKind(){
          return !('kind' in request.resource.data)
            || request.resource.data.kind in ['text','image','post','wiki'];
        }

        function hasText(){
          return ('text' in request.resource.data)
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 2000;
        }

        function isValidReply(){
          return !('replyTo' in request.resource.data)
            || (
              request.resource.data.replyTo is map
              && request.resource.data.replyTo.messageId is string
            );
        }

        function isValidImage(){
          return request.resource.data.kind == 'image'
            && request.resource.data.imageURL is string
            && request.resource.data.imageURL.size() > 0;
        }

        function isValidPost(){
          return request.resource.data.kind == 'post'
            && request.resource.data.postId is string
            && exists(/databases/$(database)/documents/communityPosts/$(request.resource.data.postId));
        }

        function isValidWiki(){
          // Wiki pages are articles with a `slug`.
          // We validate minimal structure here (slug is enough to navigate).
          return request.resource.data.kind == 'wiki'
            && request.resource.data.wikiSlug is string
            && request.resource.data.wikiSlug.size() > 0;
        }

        allow create: if isSignedIn()
                      && !isBanned(request.auth.uid)
                      && exists(/databases/$(database)/documents/chats/$(chatId))
                      && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
                      && request.resource.data.senderUid == request.auth.uid
                      && isValidMessageKind()
                      && isValidReply()
                      && (
                        // Default/text messages
                        ((!('kind' in request.resource.data) || request.resource.data.kind == 'text') && hasText())
                        ||
                        // Rich messages
                        (request.resource.data.kind == 'image' && isValidImage())
                        ||
                        (request.resource.data.kind == 'post' && isValidPost())
                        ||
                        (request.resource.data.kind == 'wiki' && isValidWiki())
                      );

        allow update, delete: if false;
      }
    }

    match /avatarPresets/{id} {
  		allow read: if true;
  		allow write: if false;
		}
     // Problem templates (optional): public read; only admins manage
    match /problemTemplates/{templateId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Game attempts and per-attempt items
    match /gameAttempts/{attemptId} {
      // Anyone can read attempts (for leaderboards)
      allow read: if true;

      // Only the signed-in owner can create their own attempt
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      // Allow owner to finalize limited fields at the end of attempt
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'endedAt','score','total','correct','rating'
                    ]);
      // No deletes
      allow delete: if false;

      // Attempt items: allow owner to create items under their attempt
      match /items/{itemId} {
        allow read: if true;
        allow create: if request.auth != null
                      && get(/databases/$(database)/documents/gameAttempts/$(attemptId)).data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    
    // Question banks per mode
    match /questions_timed/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }
    match /questions_rating/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }
    match /questions_custom/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // -----------------------------
    // Daily Challenge
    // -----------------------------

    // Public read of daily challenge docs (answer is encrypted server-side).
    // No direct client writes for problems/submissions/picks; Cloud Functions (Admin SDK) bypass rules.
    match /dailyChallenges/{dateKey} {
      allow read: if true;
      allow create, update, delete: if false;

      // New model: problems are stored per difficulty level:
      // dailyChallenges/{dateKey}/levels/{levelKey}
      match /levels/{levelKey} {
        allow read: if true;
        allow write: if false;

        function levelDoc(){
          return get(/databases/$(database)/documents/dailyChallenges/$(dateKey)/levels/$(levelKey));
        }

        function deadlineAt(){
          return ('deadlineAt' in levelDoc().data) ? levelDoc().data.deadlineAt : null;
        }

        function afterDeadline(){
          return (deadlineAt() is timestamp) && (request.time >= deadlineAt());
        }

        // Submissions are handled via callable function; keep these private by default.
        match /submissions/{uid} {
        allow read: if false;
          allow write: if false;
        }

        // Community + official solutions.
        // Stored by concept key (unique per dateKey+levelKey).
        // dailyChallenges/{dateKey}/levels/{levelKey}/solutions/{solutionId}
        match /solutions/{solutionId} {
          function isOwner(){
            return isSignedIn()
              && ('createdBy' in resource.data)
              && resource.data.createdBy == request.auth.uid;
          }

          function isApproved(){
            return ('approved' in resource.data) && resource.data.approved == true;
          }

          // Visibility:
          // - Always visible to admins and the solution owner
          // - Visible to everyone else only after the deadline AND after admin approval
          allow read: if isAdmin() || isOwner() || (afterDeadline() && isApproved());

          function isValidBlock(b){
            return b is map
              && ('type' in b)
              && (
                (b.type == 'text'
                  && ('text' in b)
                  && b.text is string
                  && b.text.size() >= 0
                  && b.text.size() <= 8000
                )
                ||
                (b.type == 'image'
                  && ('imageURL' in b)
                  && b.imageURL is string
                  && b.imageURL.size() > 0
                  && b.imageURL.size() <= 2000
                  && (!('caption' in b) || (b.caption is string && b.caption.size() <= 200))
                )
              );
          }

          function isValidBlocks(blocks){
            // Avoid `list.all(...)` due to Rules Playground issues.
            // Cap at 12 blocks for now (enough for alternating text/image).
            return (blocks is list)
              && blocks.size() >= 1
              && blocks.size() <= 12
              && (
                blocks.size() == 1 ? isValidBlock(blocks[0]) :
                blocks.size() == 2 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1])) :
                blocks.size() == 3 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2])) :
                blocks.size() == 4 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3])) :
                blocks.size() == 5 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4])) :
                blocks.size() == 6 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4]) && isValidBlock(blocks[5])) :
                blocks.size() == 7 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4]) && isValidBlock(blocks[5]) && isValidBlock(blocks[6])) :
                blocks.size() == 8 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4]) && isValidBlock(blocks[5]) && isValidBlock(blocks[6]) && isValidBlock(blocks[7])) :
                blocks.size() == 9 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4]) && isValidBlock(blocks[5]) && isValidBlock(blocks[6]) && isValidBlock(blocks[7]) && isValidBlock(blocks[8])) :
                blocks.size() == 10 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4]) && isValidBlock(blocks[5]) && isValidBlock(blocks[6]) && isValidBlock(blocks[7]) && isValidBlock(blocks[8]) && isValidBlock(blocks[9])) :
                blocks.size() == 11 ? (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4]) && isValidBlock(blocks[5]) && isValidBlock(blocks[6]) && isValidBlock(blocks[7]) && isValidBlock(blocks[8]) && isValidBlock(blocks[9]) && isValidBlock(blocks[10])) :
                (isValidBlock(blocks[0]) && isValidBlock(blocks[1]) && isValidBlock(blocks[2]) && isValidBlock(blocks[3]) && isValidBlock(blocks[4]) && isValidBlock(blocks[5]) && isValidBlock(blocks[6]) && isValidBlock(blocks[7]) && isValidBlock(blocks[8]) && isValidBlock(blocks[9]) && isValidBlock(blocks[10]) && isValidBlock(blocks[11]))
              );
          }

          function isValidSolution(){
            return request.resource.data.concept is string
              && request.resource.data.concept.size() >= 2
              && request.resource.data.concept.size() <= 60
              && request.resource.data.conceptKey is string
              && request.resource.data.conceptKey == solutionId
              && request.resource.data.conceptKey.size() >= 2
              && request.resource.data.conceptKey.size() <= 64
              && ('blocks' in request.resource.data)
              && isValidBlocks(request.resource.data.blocks)
              && request.resource.data.createdBy == request.auth.uid
              && request.resource.data.createdAt is timestamp
              // Approval fields:
              && ('approved' in request.resource.data)
              && request.resource.data.approved is bool
              && (!request.resource.data.approved || isAdmin());
          }

          // Reserve solutionId="official" for admins.
          allow create: if isSignedIn()
                        && (solutionId != 'official' || isAdmin())
                        && (afterDeadline() || isAdmin())
                        && isValidSolution();

          allow update: if isSignedIn()
                        && (isOwner() || isAdmin())
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                          'concept','conceptKey','blocks','updatedAt',
                          'approved','approvedAt','approvedBy'
                        ])
                        && request.resource.data.conceptKey == solutionId
                        && ('blocks' in request.resource.data)
                        && isValidBlocks(request.resource.data.blocks)
                        // Owners can edit only while unapproved (keeps admin verification meaningful).
                        && (
                          isAdmin()
                          || (
                            isOwner()
                            && (!('approved' in resource.data) || resource.data.approved == false)
                            && (!('approved' in request.resource.data) || request.resource.data.approved == false)
                          )
                        );

          allow delete: if isSignedIn()
                        && (
                          isAdmin()
                          || (isOwner() && (!('approved' in resource.data) || resource.data.approved == false))
                        );
        }
      }

      // Per-user daily difficulty pick (readable by owner; written by Cloud Functions only).
      match /userPicks/{uid} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // Daily edit requests (admin verification workflow).
    // dailyEditRequests/{id} created by users; approved/rejected by admins via Cloud Functions (Admin SDK).
    match /dailyEditRequests/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.kind in ['problem','solution']
                    && request.resource.data.dateKey is string
                    && request.resource.data.levelKey is string
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // Leaderboard stats: public read; no direct client writes.
    match /challengeStats/{uid} {
      allow read: if true;
      allow write: if false;

      match /days/{dateKey} {
        allow read: if false;
        allow write: if false;
      }
    }

    // New per-difficulty leaderboards (written by Cloud Functions; public read of summary).
    match /challengeStatsLevels/{levelKey}/users/{uid} {
      allow read: if true;
      allow write: if false;

      match /days/{dateKey} {
        allow read: if false;
        allow write: if false;
      }
    }
    
  }
}